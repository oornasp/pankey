<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- Run as background agent — no Dock icon, menu bar only -->
    <key>LSUIElement</key>
    <true/>

    <!-- Pixel font bundled with app -->
    <key>ATSApplicationFontsPath</key>
    <string>PressStart2P-Regular.ttf</string>

    <!-- Required usage description for Accessibility (CGEventTap) -->
    <key>NSAccessibilityUsageDescription</key>
    <string>Pankey needs Accessibility access to intercept and convert keystrokes to Vietnamese.</string>
</dict>
</plist>
