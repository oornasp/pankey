<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- IME registration: connection name must match bundle ID -->
    <key>InputMethodConnectionName</key>
    <string>io.pankey.Pankey.inputmethod</string>

    <!-- IME controller class name (unqualified — InputMethodKit resolves within bundle) -->
    <key>InputMethodServerControllerClass</key>
    <string>InputController</string>

    <!-- Input mode descriptors -->
    <key>ComponentInputModeDict</key>
    <dict>
        <key>io.pankey.Pankey.inputmethod.Telex</key>
        <dict>
            <key>IMKInputModeNameKey</key>
            <string>Telex</string>
            <key>IMKLanguageKey</key>
            <string>vi</string>
        </dict>
        <key>io.pankey.Pankey.inputmethod.VNI</key>
        <dict>
            <key>IMKInputModeNameKey</key>
            <string>VNI</string>
            <key>IMKLanguageKey</key>
            <string>vi</string>
        </dict>
    </dict>

    <!-- Run as background agent (no Dock icon) -->
    <key>LSUIElement</key>
    <true/>

    <!-- Pixel font bundle path -->
    <key>ATSApplicationFontsPath</key>
    <string>PressStart2P-Regular.ttf</string>
</dict>
</plist>
